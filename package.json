{
  "name": "@venterra/specs",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build && tsx src/compiler/cli.ts compile-all --out-dir ./dist/compiled-specs --spec-dir ./specs",
    "dev": "vite",
    "compile-spec": "tsx src/compiler/cli.ts",
    "compile-all": "tsx src/compiler/cli.ts compile-all",
    "test": "vitest run",
    "extract": "tsx src/extractor/cli.ts extract",
    "extract-all": "tsx src/extractor/cli.ts extract-all",
    "predeploy": "tsx src/compiler/cli.ts compile-all --out-dir ./public/compiled-specs --spec-dir ./specs",
    "deploy": "vite build && tsx src/compiler/cli.ts compile-all --out-dir ./dist/compiled-specs --spec-dir ./specs && cp -r functions dist/",
    "fix-sections": "node --input-type=module -e \"import fs from 'fs'; let c=fs.readFileSync('./src/layouts/pages/homepage.json','utf8'); c=c.replace(/\\\"section_01\\\"/g,'\\\"1\\\"').replace(/\\\"section_02\\\"/g,'\\\"2\\\"').replace(/\\\"section_03\\\"/g,'\\\"3\\\"').replace(/\\\"section_04\\\"/g,'\\\"4\\\"').replace(/\\\"section_05\\\"/g,'\\\"5\\\"').replace(/\\\"section_06\\\"/g,'\\\"6\\\"').replace(/\\\"section_07\\\"/g,'\\\"7\\\"').replace(/\\\"section_08\\\"/g,'\\\"8\\\"').replace(/\\\"section_09\\\"/g,'\\\"9\\\"').replace(/\\\"section_10\\\"/g,'\\\"10\\\"'); fs.writeFileSync('./src/layouts/pages/homepage.json',c,'utf8'); console.log('✅ Fixed');\""
  },
